OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_GEMINI_API_KEY=
MISTRAL_API_KEY=

# Code privé demandé avant d'utiliser /api/generate
PAUL_IA_ACCESS_CODE=

# Optionnel pour les images OpenAI
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=auto
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_COMPRESSION=
OPENAI_IMAGE_MODERATION=auto

# Optionnel pour analyser une photo envoyée par l'utilisateur
OPENAI_VISION_MODEL=gpt-5
OPENAI_VISION_DETAIL=auto

# Optionnel pour écouter les réponses avec OpenAI Audio
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_FORMAT=mp3

# Optionnel pour utiliser ta voix ElevenLabs dans "Ecouter la reponse"
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optionnel pour dicter une demande ou envoyer un fichier audio
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Optionnel pour l'agent vocal en direct
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_VOICE=marin
